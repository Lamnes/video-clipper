# Required
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# Required for style transfer (optional feature)
FAL_API_KEY=your-fal-key-here

# Optional overrides
# PORT=8080
# STT_MODEL=google/gemini-2.5-flash
# ANALYSIS_MODEL=anthropic/claude-sonnet-4
# REVIEWER_MODEL=google/gemini-2.5-flash
# MAX_REVIEW_ROUNDS=2

# OpenRouter Fusion for highlight selection (multi-model panel + judge).
# More semantically reliable picks; costs several completions per call.
# ANALYSIS_FUSION=true
# FUSION_PANEL=anthropic/claude-sonnet-4,google/gemini-2.5-flash,openai/gpt-4o-mini
# FUSION_JUDGE=anthropic/claude-sonnet-4
# FUSION_MAX_TOOL_CALLS=2

# FAL_STYLE_MODEL=fal-ai/wan/v2.1/video-to-video
# MAX_CONCURRENT_JOBS=2
# MAX_CLIPS=20
# MIN_CLIP_DURATION=10
# MAX_CLIP_DURATION=60
# MAX_UPLOAD_MB=4096
# RUST_LOG=info
